[cli]
flavour = RDM
logfile = /logs/invenio-cli.log

[cookiecutter]
project_name = rdm-app
project_shortname = rdm-app
package_name = rdm_app
project_site = rdm-app.com
author_name = CERN
author_email = info@rdm-app.com
year = 2026
database = postgresql
search = opensearch2
file_storage = local
development_tools = yes
site_code = yes
use_reduced_vocabs = no
_template = https://github.com/inveniosoftware/cookiecutter-invenio-rdm.git
_output_dir = /opt/app-root/data
_repo_dir = /root/.cookiecutters/cookiecutter-invenio-rdm
_checkout = v13.0

