{
    "name": "RDM Workspace Development Environment",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "features": {
        "ghcr.io/devcontainers/features/docker-in-docker:2": {
            "version": "latest",
            "enableNonRootDocker": "true",
            "moby": "true"
        },
        "ghcr.io/devcontainers/features/python:1": {
            "version": "3.12"
        }
    },
    "containerEnv": {
        "PIPENV_CUSTOM_VENV_NAME": "rdm-venv"
    },
    "updateContentCommand": "rm -f .rdm-ready",
    "postCreateCommand": "/workspaces/rdm-instance/rdm-app/setup-services.sh",
    "postStartCommand": "/workspaces/rdm-instance/rdm-app/start-dev-services.sh",
    "remoteUser": "root",
    "workspaceFolder": "/workspaces/rdm-instance/rdm-app",
    "forwardPorts": [
        5050,
        5601
    ],
    "customizations": {
        "vscode": {
            "settings": {
                "editor.formatOnSave": true
            },
            "extensions": [
                "/workspaces/rdm-instance/.vscode/vscode-extensions/rdm-assets/rdm-assets-0.0.1.vsix",
                "samuelcolvin.jinjahtml"
            ]
        }
    },
    "mounts": [
        "source=${localEnv:HOME}/.aws,target=/root/.aws,type=bind"
    ]
}